        "contentType": "raw",
        "rawContentType": "JSON",
        "body": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a senior AI configuration engineer. Your job is to update an existing JSON config (v1) with new rules extracted from a fresh onboarding transcript. You must return a JSON object with exactly these keys: 'v2_memo' (the updated configuration), 'v2_spec' (the system prompt and extracted data), and 'changelog' (an array of strings describing what changed).\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Here is the V1 configuration: {{ $node['Read/Write Files from Disk1'].json.memo }}\\n\\nHere is the new onboarding transcript: {{ $node['Code in JavaScript'].json.clean_transcript }}\\n\\nUpdate the config now. Ensure 'v2_spec' contains the conversational rules (Greeting, Transfer, Fallback, etc). Do not return empty objects.\"\n    }\n  ],\n  \"response_format\": { \"type\": \"json_object\" }\n}",
