      "parameters": {
        "jsCode": "// Parse the response\nconst rawContent = $input.first().json.choices[0].message.content;\nconst data = JSON.parse(rawContent);\n\nreturn {\n  json: { success: true },\n  binary: {\n    memo_v2: {\n      data: Buffer.from(JSON.stringify(data.v2_memo, null, 2)).toString('base64'),\n      mimeType: 'application/json',\n      fileName: 'memo.json'\n    },\n    spec_v2: {\n      data: Buffer.from(JSON.stringify(data.v2_spec, null, 2)).toString('base64'),\n      mimeType: 'application/json',\n      fileName: 'agent_spec.json'\n    },\n    changelog: {\n      data: Buffer.from(data.changelog.join('\\n')).toString('base64'),\n      mimeType: 'text/markdown',\n      fileName: 'bens_electric_changes.md'\n    }\n  }\n};"
